generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Better Auth Tables
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope        String?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier  String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([identifier])
}

// Application Tables
model Cookie {
  id                Int             @id @default(autoincrement())
  label             String          @unique
  agentRouterCookie String?         // Cookie for agentrouter.org domain
  githubCookie      String?         // Cookie for github.com domain
  status            String          @default("UNKNOWN") // ACTIVE, EXPIRED, UNKNOWN
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  schedules         Schedule[]
  logs              Log[]
  accountData       AccountData?
  redemptionLogs    RedemptionLog[]
  accounts          RouterAccount[]
}

model RouterAccount {
  id        Int      @id @default(autoincrement())
  username  String
  name      String
  cookieId  Int      @unique
  authId   String?  // Link to Better Auth User
  cookie    Cookie   @relation(fields: [cookieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id        Int      @id @default(autoincrement())
  name      String
  cookieId  Int
  cookie    Cookie   @relation(fields: [cookieId], references: [id], onDelete: Cascade)
  time      String   // HH:mm format
  frequency String   @default("DAILY") // DAILY, WEEKLY, CUSTOM
  type      String   // LOGIN, LOGOUT, LOGIN_THEN_LOGOUT
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      Log[]
}

model Log {
  id         Int         @id @default(autoincrement())
  scheduleId Int?
  schedule   Schedule?   @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  cookieId   Int?
  cookie     Cookie?     @relation(fields: [cookieId], references: [id], onDelete: SetNull)
  actionType String      // LOGIN, LOGOUT
  status     String      // SUCCESS, FAILED, RUNNING
  response   String?
  executedAt DateTime    @default(now())
  entries    LogEntry[]
}

model LogEntry {
  id        Int      @id @default(autoincrement())
  logId     Int
  log       Log      @relation(fields: [logId], references: [id], onDelete: Cascade)
  step      String   // Name of the step (e.g., "Starting API request", "Validating cookie")
  level     String   // INFO, WARN, ERROR, DEBUG
  message   String   // Detailed message of the step
  metadata  String?  // JSON string for additional data (request/response body, headers, etc.)
  timestamp DateTime @default(now())
}

model AccountData {
  id              Int            @id @default(autoincrement())
  cookieId        Int            @unique
  cookie          Cookie         @relation(fields: [cookieId], references: [id], onDelete: Cascade)
  currentBalance  String?
  consumption     String?
  lastUpdated     DateTime       @updatedAt
  createdAt       DateTime       @default(now())
  redemptionLogs  RedemptionLog[]
}

model RedemptionLog {
  id              Int         @id @default(autoincrement())
  accountDataId   Int
  accountData     AccountData @relation(fields: [accountDataId], references: [id], onDelete: Cascade)
  cookieId        Int
  cookie          Cookie      @relation(fields: [cookieId], references: [id], onDelete: Cascade)
  nominal         String
  auditableData   String
  previousBalance String
  newBalance      String
  createdAt       DateTime    @default(now())
}
